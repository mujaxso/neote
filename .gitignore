# Aider
.aider*

# Compiled files
target/
**/*.rs.bk

# Cargo.lock is generated for applications, not libraries
# This workspace contains binaries, so we commit Cargo.lock
# Cargo.lock

# IDE specific files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build artifacts
**/*.o
**/*.so
**/*.dylib

# Coverage
coverage/
*.profraw

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Temporary files
tmp/
temp/

# GitHub Actions custom actions
.github/actions/

# Runtime directory - contains downloaded and compiled Tree-sitter grammars
# Keep the directory structure but ignore all contents
runtime/treesitter/grammars/**
runtime/treesitter/languages/**
!runtime/treesitter/grammars/
!runtime/treesitter/languages/
# Also ignore any files directly in runtime/treesitter
runtime/treesitter/*
!runtime/treesitter/grammars
!runtime/treesitter/languages
